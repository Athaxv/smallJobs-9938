{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.smalljobs_k7p2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "apiUrl": "https://smalljobs-3kyj.onrender.com",
      "router": {},
      "eas": {
        "projectId": "eb61e878-dc04-4312-af47-3d36c1bed7af"
      }
    },
    "ios": {
      "bundleIdentifier": "com.smalljobs_k7p2.runable",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "name": "SmallJobs",
    "slug": "smalljobs",
    "version": "1.0.0",
    "scheme": "mobile",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SmallJobs needs your location to show nearby gigs."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#111111"
        }
      ]
    ]
  }
}
