# Environment
NODE_ENV=development
# Public URL of this deployment (Render: https://your-app.onrender.com — no trailing slash)
WEBSITE_URL=http://localhost:4200

# Better Auth - Configuration
BETTER_AUTH_SECRET=randomaddlong

# Database (Turso)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Gateway Configuration
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# Payments and tracking
AUTUMN_SECRET_KEY=

# Optional: full URL if APK is hosted elsewhere (default: /smalljobs.apk on this site)
# VITE_APK_DOWNLOAD_URL=https://your-cdn.com/smalljobs.apk

# Expo Push (optional; recommended on Render for production push volume)
EXPO_ACCESS_TOKEN=

# Mobile push: rebuild EAS dev/preview APK after expo-notifications plugin changes.
# Android SDK 53+ push may not work in Expo Go — use an EAS build for testing.

# Optional: web search for AI deadline resolution (https://serper.dev)
SERPER_API_KEY=
